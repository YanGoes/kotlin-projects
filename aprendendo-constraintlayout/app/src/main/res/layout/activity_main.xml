    <TextView
        android:id="@+id/user_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Olá, João Cunha!"
        android:textSize="20dp"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />


    <TextView
        android:id="@+id/question_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="O que vamos aprender hoje?"
        android:paddingTop="12dp"
        android:textStyle="bold"
        android:layout_marginStart="10dp"
        android:textSize="22sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/user_name"
        />


    <ImageView
        android:id="@+id/image_development"
        android:layout_width="150dp"
        android:layout_height="140dp"
        android:layout_marginTop="40dp"
        android:angle="0"
        android:src="@drawable/image_development"
        app:layout_constraintEnd_toStartOf="@+id/image_desing"
        app:layout_constraintHorizontal_bias="0.521"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/question_text" />


    <ImageView
        android:id="@+id/image_desing"
        android:layout_width="150dp"
        android:layout_height="140dp"
        android:layout_marginEnd="44dp"
        android:angle="0"
        android:src="@drawable/image_design"
        app:layout_constraintEnd_toEndOf="parent"
        tools:layout_editor_absoluteY="117dp" />


    <ImageView
        android:id="@+id/image_ai"
        android:layout_width="150dp"
        android:layout_height="140dp"
        android:layout_marginTop="28dp"
        android:angle="0"
        android:src="@drawable/image_ai"
        app:layout_constraintEnd_toStartOf="@+id/image_explore"
        app:layout_constraintHorizontal_bias="0.492"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image_development" />

    <ImageView
        android:id="@+id/image_explore"
        android:layout_width="150dp"
        android:layout_height="140dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/image_explore"
        android:angle="0"
        tools:layout_editor_absoluteX="221dp"
        tools:layout_editor_absoluteY="278dp" />

    <TextView
        android:id="@+id/tv_cursos_populares"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="12dp"
        android:textSize="14sp"
        android:text="Cursos populares"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image_ai"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="449dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="Ver todos"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/tv_cursos_populares"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="12dp"
        android:paddingStart="24dp"
        android:layout_margin="16dp"
        android:layout_weight="1"
        android:background="@drawable/bg_degrade"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        android:text="Desenvolvimento Android"
        android:textColor="#4A4A4A"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_cursos_populares"
        tools:layout_editor_absoluteX="35dp"
        tools:layout_editor_absoluteY="494dp" />

    <ImageView
        android:id="@+id/imgAndroid"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/android"
        app:layout_constraintBottom_toBottomOf="@id/txtTitulo"
        app:layout_constraintEnd_toEndOf="@id/txtTitulo"
        app:layout_constraintTop_toTopOf="@id/txtTitulo"
        tools:layout_editor_absoluteX="334dp"
        tools:layout_editor_absoluteY="504dp" />


</androidx.constraintlayout.widget.ConstraintLayout>
